---
// components
import Navbar from "../components/Navbar";
import Footer from "../components/Footer";

// props
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <Navbar client:load />
    <slot />
    <Footer />
  </body>
</html>
